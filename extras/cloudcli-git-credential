#!/bin/bash
# Git credential helper: reads the active GitHub PAT from CloudCLI's SQLite DB.
#
# Behavior:
#   1) If stdin contains `username=<name>` (because a repo has
#      `credential.<remote>.username=<name>` set — done via `cloudcli-project token`),
#      look up a CloudCLI token with credential_name=<name> and return it.
#   2) Otherwise, fall back to the single `is_active=1` github_token in the DB
#      (the "global" token set from Settings → API & Tokens).
#
# Wired globally at /etc/gitconfig so CloudCLI's UI (which writes ~/.gitconfig)
# cannot clobber it.
set -u

action="${1:-}"
[ "$action" = "get" ] || exit 0

host=""
proto=""
username=""
while IFS= read -r line; do
	[ -z "$line" ] && break
	key="${line%%=*}"
	val="${line#*=}"
	case "$key" in
		host)     host="$val" ;;
		protocol) proto="$val" ;;
		username) username="$val" ;;
	esac
done

# Only answer for https://github.com
[ "$proto" = "https" ] || exit 0
[ "$host" = "github.com" ] || exit 0

DB=/home/node/.cloudcli/auth.db
[ -r "$DB" ] || exit 0

sql_quote() {
	# escape single quotes for SQLite: ' -> ''
	printf "'%s'" "$(printf '%s' "$1" | sed "s/'/''/g")"
}

token=""

# 1) Per-repo routing: caller provided a username that maps to a named token
if [ -n "$username" ]; then
	token=$(sqlite3 -noheader -batch "$DB" \
		"SELECT credential_value FROM user_credentials
		 WHERE credential_type='github_token'
		   AND credential_name=$(sql_quote "$username")
		 ORDER BY is_active DESC, created_at DESC
		 LIMIT 1;" 2>/dev/null)
fi

# 2) Fallback: active global token
if [ -z "$token" ]; then
	token=$(sqlite3 -noheader -batch "$DB" \
		"SELECT credential_value FROM user_credentials
		 WHERE credential_type='github_token' AND is_active=1
		 ORDER BY created_at DESC
		 LIMIT 1;" 2>/dev/null)
fi

[ -z "$token" ] && exit 0

# The username we echo back is cosmetic for git; what authenticates is the
# token. Any string works with fine-grained PATs.
printf 'username=%s\n' "${username:-x-access-token}"
printf 'password=%s\n' "$token"
