 /**
  * Helper function to clone a GitHub repository
  */
+/**
+ * After a successful clone:
+ *   1) Reset the remote URL to the plain form (strip any embedded PAT — it's fine to
+ *      use at clone-time, but shouldn't be persisted to .git/config, where it leaks
+ *      via `git remote -v` and becomes dead on every rotation).
+ *   2) If the credential has a per-token git_name / git_email, write them as
+ *      repo-local user.name / user.email.
+ *   3) If the credential has a name, write `credential.<remote>.username=<name>` so
+ *      future pull/push on this repo are routed by our git credential helper to the
+ *      specific token in the DB (single source of truth).
+ */
+function applyPostCloneSettings(repoPath, originalGithubUrl, tokenIdentity) {
+  return new Promise((resolve) => {
+    // SSH URLs (git@github.com:user/repo.git) are not http(s), can't be URL-parsed,
+    // and don't participate in credential.<url>.username routing. We still apply
+    // per-token git identity for them, but skip the credential routing step.
+    const isSshUrl = /^(ssh:\/\/|[\w.-]+@[\w.-]+:)/.test(originalGithubUrl);
+
+    const cleanUrl = (() => {
+      if (isSshUrl) return originalGithubUrl;
+      try { const u = new URL(originalGithubUrl); u.username = ''; u.password = ''; return u.toString().replace(/\/$/, ''); }
+      catch { return originalGithubUrl; }
+    })();
+
+    const cmds = [['git', ['-C', repoPath, 'remote', 'set-url', 'origin', cleanUrl]]];
+
+    if (tokenIdentity?.gitName) {
+      cmds.push(['git', ['-C', repoPath, 'config', '--local', 'user.name', tokenIdentity.gitName]]);
+    }
+    if (tokenIdentity?.gitEmail) {
+      cmds.push(['git', ['-C', repoPath, 'config', '--local', 'user.email', tokenIdentity.gitEmail]]);
+    }
+    // Only for https URLs: wire credential.<url>.username so our helper picks the right token
+    if (!isSshUrl && tokenIdentity?.name) {
+      const credKey = `credential.${cleanUrl.replace(/\.git$/, '')}.username`;
+      cmds.push(['git', ['-C', repoPath, 'config', '--local', credKey, tokenIdentity.name]]);
+    }
+
+    let i = 0;
+    const runNext = () => {
+      if (i >= cmds.length) return resolve();
+      const [bin, args] = cmds[i++];
+      const p = spawn(bin, args, { stdio: 'ignore' });
+      p.on('close', runNext);
+      p.on('error', runNext); // best-effort; don't fail the clone on post-config issues
+    };
+    runNext();
+  });
+}
