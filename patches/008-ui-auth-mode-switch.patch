+/**
+ * Inspect a repo's `origin` URL and any credential.<url>.username override to return
+ *   { mode: 'ssh' | 'https' | 'unknown', tokenName: string | null }
+ * Used by the UI to show a per-repo auth-mode toggle.
+ */
+async function detectAuthMode(projectPath, remoteName = 'origin') {
+  try {
+    const { stdout: url } = await spawnAsync('git', ['remote', 'get-url', remoteName], { cwd: projectPath });
+    const u = (url || '').trim();
+    if (/^git@|^ssh:\/\//.test(u)) {
+      return { mode: 'ssh', tokenName: null };
+    }
+    if (/^https?:\/\//.test(u)) {
+      // Look up a per-repo credential.<url>.username override; strip any embedded user@ and .git for the key
+      const key = `credential.${u.replace(/:\/\/[^@]+@/, '://').replace(/\/$/, '').replace(/\.git$/, '')}.username`;
+      let tokenName = null;
+      try {
+        const { stdout } = await spawnAsync('git', ['config', '--local', '--get', key], { cwd: projectPath });
+        tokenName = stdout.trim() || null;
+      } catch (_) {}
+      return { mode: 'https', tokenName };
+    }
+    return { mode: 'unknown', tokenName: null };
+  } catch (_) {
+    return { mode: 'unknown', tokenName: null };
+  }
+}
+
+/**
+ * Flip a repo's remote between HTTPS and SSH form + (optionally) pin a token for HTTPS routing.
+ * POST /api/git/auth-mode  { project: string, mode: 'https' | 'ssh', tokenName?: string }
+ */
+router.post('/auth-mode', async (req, res) => {
+  const { project, mode, tokenName } = req.body || {};
+  if (!project)        return res.status(400).json({ error: 'Project name is required' });
+  if (mode !== 'https' && mode !== 'ssh') return res.status(400).json({ error: "mode must be 'https' or 'ssh'" });
+
+  try {
+    const projectPath = await getActualProjectPath(project);
+    await validateGitRepository(projectPath);
+
+    const { stdout: urlOut } = await spawnAsync('git', ['remote', 'get-url', 'origin'], { cwd: projectPath });
+    const current = (urlOut || '').trim();
+    if (!current) return res.status(400).json({ error: 'repo has no origin remote' });
+
+    // derive owner/repo from either form
+    let owner = null, repo = null;
+    let m = current.match(/^https?:\/\/(?:[^@]+@)?github\.com\/([^/]+)\/(.+?)(?:\.git)?\/?$/i);
+    if (m) { owner = m[1]; repo = m[2]; }
+    else {
+      m = current.match(/^git@github\.com:([^/]+)\/(.+?)(?:\.git)?$/i);
+      if (m) { owner = m[1]; repo = m[2]; }
+    }
+    if (!owner || !repo) {
+      return res.status(400).json({ error: 'origin does not look like a github.com URL (only github is currently supported)' });
+    }
+
+    const httpsClean = `https://github.com/${owner}/${repo}`;
+    const sshUrl = `git@github.com:${owner}/${repo}.git`;
+    const targetUrl = mode === 'ssh' ? sshUrl : `${httpsClean}.git`;
+
+    await spawnAsync('git', ['remote', 'set-url', 'origin', targetUrl], { cwd: projectPath });
+
+    // SSH: strip any leftover credential.<url>.username section so we don't confuse future operations.
+    const credSection = `credential.${httpsClean}`;
+    if (mode === 'ssh') {
+      try { await spawnAsync('git', ['config', '--local', '--remove-section', credSection], { cwd: projectPath }); }
+      catch (_) {}
+    } else if (tokenName && tokenName.trim()) {
+      // HTTPS + explicit token routing
+      await spawnAsync('git', ['config', '--local', `${credSection}.username`, tokenName.trim()], { cwd: projectPath });
+    }
+
+    const authInfo = await detectAuthMode(projectPath);
+    res.json({ success: true, remote: targetUrl, authMode: authInfo.mode, authTokenName: authInfo.tokenName });
+  } catch (error) {
+    console.error('Git auth-mode error:', error);
+    res.status(500).json({ error: error.message });
+  }
+});
