+  enabled,
+  writer,
+  sessionId,
+  provider,
+  summary,
+  input,
+  context,
+}) => {
+  if (!enabled) {
+    return { allow: true, message: '' };
+  }
+
+  return waitForBuilderApproval({
+    writer,
+    sessionId,
+    provider,
+    summary,
+    input,
+    context,
+  });
+};
+
+const readJsonFile = async (filePath) => {
+  try {
+    const raw = await fs.readFile(filePath, 'utf8');
+    const parsed = JSON.parse(raw);
+    return parsed && typeof parsed === 'object' ? parsed : {};
+  } catch {
+    return {};
+  }
+};
+
+const detectProjectScripts = async (projectPath) => {
+  try {
+    const raw = await fs.readFile(path.join(projectPath, 'package.json'), 'utf8');
+    const parsed = JSON.parse(raw);
+    return {
+      scripts: parsed?.scripts && typeof parsed.scripts === 'object' ? parsed.scripts : {},
+      packageConfig: parsed?.cloudcli?.builder && typeof parsed.cloudcli.builder === 'object'
