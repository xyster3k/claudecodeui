+};
+
+const persistRunArtifacts = async (projectPath, sessionId, prdMarkdown, tasks, config) => {
+  await ensureDirectories(projectPath);
+
+  const prdPath = path.join(projectPath, TASKMASTER_DIR, 'docs', `cloudcli-builder-${sanitizeFileName(sessionId)}.md`);
+  const tasksPath = path.join(projectPath, TASKMASTER_DIR, 'tasks', 'tasks.json');
+  const runPath = path.join(projectPath, BUILDER_ARTIFACT_DIR, `${sanitizeFileName(sessionId)}.json`);
+  const latestPath = path.join(projectPath, BUILDER_ARTIFACT_DIR, 'latest-run.json');
+  const configExamplePath = path.join(projectPath, '.cloudcli', 'builder.example.json');
+  const configTemplate = {
+    orchestration: {
+      maxParallelWorkers: 2,
+      maxWorkers: 6,
+      workerModel: 'gpt-5.4-mini',
+      integratorModel: 'gpt-5.5',
+    },
+    approvals: {
+      riskyChanges: true,
+      merge: true,
+      production: true,
+    },
+    merge: {
+      command: 'git push origin HEAD:main',
+      branch: 'main',
+    },
+    production: {
+      command: 'npm run deploy:production',
+    },
+  };
+
+  await fs.mkdir(path.dirname(configExamplePath), { recursive: true });
+  await fs.writeFile(prdPath, `${prdMarkdown}\n`, 'utf8');
+  await fs.writeFile(tasksPath, `${JSON.stringify({ tasks }, null, 2)}\n`, 'utf8');
+  await fs.writeFile(runPath, `${JSON.stringify({ sessionId, prdPath, tasksPath, config }, null, 2)}\n`, 'utf8');
+  await fs.writeFile(latestPath, `${JSON.stringify({ sessionId, prdPath, tasksPath, config }, null, 2)}\n`, 'utf8');
+
+  try {
+    await fs.access(configExamplePath);
