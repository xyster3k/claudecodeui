+
+    return {
+      projectStateSummary,
+      languages: languages.length > 0 ? languages : ['Primary site language'],
+      pages: pages.length > 0 ? pages : ['Relevant feature entry points'],
+      tasks,
+      prdMarkdown: buildPrdMarkdown({
+        command,
+        projectPath,
+        projectStateSummary,
+        languages: languages.length > 0 ? languages : ['Primary site language'],
+        pages: pages.length > 0 ? pages : ['Relevant feature entry points'],
+        tasks,
+        maxParallelWorkers: parallelWorkers,
+      }),
+    };
+  } catch {
+    return fallbackPlan(command, projectPath, maxWorkers, parallelWorkers);
+  }
+};
