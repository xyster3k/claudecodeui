+    provider,
+    aborted: false,
+    childSessions: new Set(),
+  };
+  activeBuilderRuns.set(sessionId, runState);
+
+  sendNormalized(writer, {
+    kind: 'session_created',
+    newSessionId: sessionId,
+    sessionId,
+    provider,
+  });
+
+  sendTaskUpdate(writer, sessionId, provider, 'Builder workflow started', 'in_progress');
+
+  try {
+    const globalConfig = await readJsonFile(GLOBAL_BUILDER_CONFIG_PATH);
+    const { packageConfig } = await detectProjectScripts(projectPath);
+    const projectConfig = await readJsonFile(path.join(projectPath, '.cloudcli', 'builder.json'));
+    const builderConfig = withDefaultBuilderConfig(mergeBuilderConfig(globalConfig, packageConfig, projectConfig));
+    const maxWorkers = Math.max(2, Math.floor(Number(builderConfig.orchestration.maxWorkers) || DEFAULT_MAX_WORKERS));
+    const parallelWorkers = clampParallelWorkers(builderConfig.orchestration.maxParallelWorkers);
+    const plannerModel = builderConfig.orchestration.plannerModel
+      || defaultPlannerModelForProvider(provider, options.model);
+    const workerModel = builderConfig.orchestration.workerModel
+      || defaultWorkerModelForProvider(provider, options.model);
+    const integratorModel = builderConfig.orchestration.integratorModel
+      || defaultPlannerModelForProvider(provider, options.model);
+
+    sendTaskUpdate(writer, sessionId, provider, 'Planner inspecting current project state', 'in_progress');
+
+    const registerChildSession = (childSessionId) => {
+      if (childSessionId) {
+        runState.childSessions.add(childSessionId);
+      }
+    };
+
+    const plannerWriter = new BufferedWriter(`${sessionId}-planner`, provider, registerChildSession);
+    await runProviderTask({
+      runner,
+      prompt: buildPlannerPrompt({
+        command,
+        projectPath,
+        maxWorkers,
+        parallelWorkers,
+      }),
+      options: {
+        ...options,
+        cwd: projectPath,
+        projectPath,
+        model: plannerModel || options.model,
+      },
+      writer: plannerWriter,
+    });
+
