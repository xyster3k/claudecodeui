+  sendNormalized(writer, {
+    kind: 'permission_request',
+    sessionId,
+    provider,
+    requestId,
+    toolName: 'BuilderApproval',
+    source: 'builder',
+    input,
+    context: {
+      summary,
+      ...(context || {}),
+    },
+  });
+});
