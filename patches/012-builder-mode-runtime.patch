+export async function runBuilderWorkflow(command, options = {}, writer, provider = 'claude') {
+  const sessionId = `builder-${randomUUID()}`;
+  const projectPath = options.projectPath || options.cwd || process.cwd();
+  const runner = PROVIDER_RUNNERS[provider] || queryClaudeSDK;
