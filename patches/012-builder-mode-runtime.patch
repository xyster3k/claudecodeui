+class BufferedWriter {
+  constructor(sessionId, provider, onSessionId = null) {
+    this.sessionId = sessionId;
+    this.provider = provider;
+    this.sessionHistory = [];
+    this.textChunks = [];
+    this.errors = [];
+    this.onSessionId = onSessionId;
+  }
+
+  send(message) {
+    this.sessionHistory.push(message);
+    if (message?.newSessionId) {
+      this.sessionId = message.newSessionId;
+      this.onSessionId?.(this.sessionId);
+    } else if (message?.sessionId) {
+      this.sessionId = message.sessionId;
+      this.onSessionId?.(this.sessionId);
+    }
+
+    if (typeof message?.content === 'string' && (message.kind === 'text' || message.kind === 'stream_delta')) {
+      this.textChunks.push(message.content);
+    }
+    if (typeof message?.summary === 'string') {
+      this.textChunks.push(message.summary);
+    }
+    if (typeof message?.content === 'string' && message.kind === 'error') {
+      this.errors.push(message.content);
+    }
+  }
+
+  setSessionId(sessionId) {
+    this.sessionId = sessionId;
+    this.onSessionId?.(sessionId);
+  }
+
+  getSessionId() {
+    return this.sessionId;
+  }
+
+  getSummary() {
+    const text = this.textChunks.join('\n').trim();
+    return {
+      sessionId: this.sessionId,
+      provider: this.provider,
+      text: text || '',
+      errors: [...this.errors],
+    };
+  }
+}
