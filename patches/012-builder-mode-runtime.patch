+  return {
+    ...acc,
+    ...item,
+    orchestration: { ...(acc.orchestration || {}), ...(item.orchestration || {}) },
+    approvals: { ...(acc.approvals || {}), ...(item.approvals || {}) },
+    merge: { ...(acc.merge || {}), ...(item.merge || {}) },
+    production: { ...(acc.production || {}), ...(item.production || {}) },
+  };
+}, {});
