+export function resolveBuilderApproval(requestId, decision = {}) {
+  const pending = builderApprovalRequests.get(requestId);
+  if (!pending) {
+    return false;
+  }
+
+  builderApprovalRequests.delete(requestId);
+  pending.resolve({
+    allow: Boolean(decision.allow),
+    message: typeof decision.message === 'string' ? decision.message.trim() : '',
+  });
+  return true;
+}
+
+export function isBuilderWorkflowActive(sessionId) {
+  return activeBuilderRuns.has(sessionId);
+}
+
+export async function abortBuilderWorkflow(sessionId) {
+  const run = activeBuilderRuns.get(sessionId);
+  if (!run) {
+    return false;
+  }
+
+  run.aborted = true;
+  const aborter = PROVIDER_ABORTERS[run.provider];
+  const childSessions = [...run.childSessions].filter(Boolean);
+  const results = await Promise.all(childSessions.map(async (childSessionId) => {
+    try {
+      const outcome = await aborter?.(childSessionId);
+      return Boolean(outcome);
+    } catch {
+      return false;
+    }
+  }));
+
+  return results.length === 0 ? true : results.some(Boolean);
+}
