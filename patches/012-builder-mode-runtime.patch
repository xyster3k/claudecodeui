+const runProviderTask = async ({ runner, prompt, options, writer }) => {
+  await runner(prompt, {
+    ...options,
+    workflowMode: 'chat',
+  }, writer);
+};
+
+const runItemsWithConcurrency = async (items, limit, worker) => {
+  const results = new Array(items.length);
+  let currentIndex = 0;
+
+  const executeNext = async () => {
+    const index = currentIndex;
+    currentIndex += 1;
+    if (index >= items.length) {
+      return;
+    }
+
+    results[index] = await worker(items[index], index);
+    await executeNext();
+  };
+
+  const count = Math.min(limit, items.length);
+  await Promise.all(Array.from({ length: count }, () => executeNext()));
+  return results;
+};
+
+const formatWorkerResults = (results) => results.map((result) => [
+  `### Worker ${result.task.id}: ${result.task.title}`,
+  `Status: ${result.ok ? 'completed' : 'failed'}`,
+  result.summary ? result.summary : 'No worker summary captured.',
+  result.errors.length > 0 ? `Errors: ${result.errors.join(' | ')}` : '',
+].filter(Boolean).join('\n')).join('\n\n');
+
+const normalizePlannerTasks = (tasks, maxWorkers) => {
+  const normalized = Array.isArray(tasks)
+    ? tasks.map((task, index) => {
+      if (typeof task === 'string') {
+        return {
+          id: index + 1,
+          title: task.trim(),
+          details: '',
+          ownership: '',
+          status: 'pending',
+          priority: 'high',
+        };
+      }
+
+      return {
+        id: Number(task?.id) || index + 1,
+        title: readString(task?.title) || readString(task?.name) || `Task ${index + 1}`,
+        details: readString(task?.details) || readString(task?.description) || '',
+        ownership: readString(task?.ownership) || readString(task?.owner_scope) || '',
+        status: 'pending',
+        priority: readString(task?.priority) || 'high',
+      };
+    }).filter((task) => task.title)
+    : [];
+
+  return normalized.slice(0, maxWorkers).map((task, index) => ({
+    ...task,
+    id: index + 1,
+  }));
+};
+
+const fallbackPlan = (command, projectPath, maxWorkers, parallelWorkers) => {
+  const tasks = normalizePlannerTasks([
+    {
+      title: 'Repository inspection and architecture alignment',
+      details: 'Inspect the current project structure, identify the relevant implementation areas, and define concrete ownership boundaries for the remaining work.',
+      ownership: 'Read-heavy planning and shared architectural context.',
+    },
+    {
+      title: 'Primary feature implementation',
+      details: `Implement the main feature requested by the user: ${command}`,
+      ownership: 'Core logic and primary product behavior.',
+    },
+    {
+      title: 'UI and workflow integration',
+      details: 'Integrate the feature into the existing UI, routes, state flow, and user interactions.',
+      ownership: 'Screens, interactions, and integration touch points.',
+    },
+    {
+      title: 'Final integration and consistency cleanup',
+      details: 'Resolve cross-cutting issues, align naming/data flow, and stitch shared files together.',
+      ownership: 'Shared glue and consistency.',
+    },
+  ], maxWorkers);
+
+  return {
+    projectStateSummary: `Planner fallback used for project \`${projectPath}\` because structured planning output was not parsed successfully.`,
+    languages: ['Primary site language'],
+    pages: ['Relevant feature entry points'],
+    tasks,
+    prdMarkdown: buildPrdMarkdown({
+      command,
+      projectPath,
+      projectStateSummary: `Planner fallback used for project \`${projectPath}\` because structured planning output was not parsed successfully.`,
+      languages: ['Primary site language'],
+      pages: ['Relevant feature entry points'],
+      tasks,
+      maxParallelWorkers: parallelWorkers,
+    }),
+  };
+};
+
+const buildPlannerPrompt = ({ command, projectPath, maxWorkers, parallelWorkers }) => [
+  'You are the planner for Builder Mode.',
+  `Project root: ${projectPath}`,
+  '',
+  'Your job:',
