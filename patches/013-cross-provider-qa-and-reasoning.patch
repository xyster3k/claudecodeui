+const normalizeReasoningLevel = (value, fallback = 'medium') => {
+  const normalized = readString(value)?.toLowerCase();
+  if (normalized && Object.prototype.hasOwnProperty.call(REASONING_PREFIXES, normalized)) {
+    return normalized;
+  }
+
+  if (fallback && Object.prototype.hasOwnProperty.call(REASONING_PREFIXES, fallback)) {
