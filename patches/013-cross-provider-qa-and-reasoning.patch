+  if (preferred) {
+    candidates.push(preferred);
+  } else {
+    candidates.push(...(QA_PROVIDER_FALLBACKS[primaryProvider] || ['codex', 'claude']));
+  }
+
+  if (!requireDifferentProvider || preferred === primaryProvider) {
