+const FILE_PATH_KEYS = new Set([
+  'file_path',
+  'filepath',
+  'path',
+  'filename',
+  'new_path',
+  'old_path',
+  'target_file',
+]);
+
+const FILE_EDIT_TOOL_NAMES = new Set([
+  'Edit',
+  'Write',
+  'MultiEdit',
+  'NotebookEdit',
+  'FileChanges',
+]);
+
+const collectPathCandidates = (value, bucket = []) => {
+  if (Array.isArray(value)) {
+    value.forEach((entry) => collectPathCandidates(entry, bucket));
+    return bucket;
+  }
+
+  if (!value || typeof value !== 'object') {
+    return bucket;
+  }
+
+  Object.entries(value).forEach(([key, nestedValue]) => {
+    if (FILE_PATH_KEYS.has(key.toLowerCase()) && typeof nestedValue === 'string') {
+      bucket.push(nestedValue);
+      return;
+    }
+
+    if (nestedValue && typeof nestedValue === 'object') {
+      collectPathCandidates(nestedValue, bucket);
+    }
+  });
+
+  return bucket;
+};
+
+const normalizeProjectRelativePath = (projectPath, candidate) => {
+  const raw = readString(candidate);
+  if (!raw) {
+    return null;
+  }
+
+  const withoutFileScheme = raw.replace(/^file:\/\//i, '');
+  const resolved = path.isAbsolute(withoutFileScheme)
+    ? withoutFileScheme
+    : path.join(projectPath, withoutFileScheme);
+  const relative = path.relative(projectPath, resolved);
+  if (!relative || relative.startsWith('..') || path.isAbsolute(relative)) {
+    if (!path.isAbsolute(withoutFileScheme) && !withoutFileScheme.startsWith('..')) {
+      return withoutFileScheme.split(path.sep).join('/');
+    }
+    return null;
+  }
+
+  return relative.split(path.sep).join('/');
+};
+
+const extractTouchedFilesFromHistory = (sessionHistory, projectPath) => {
+  const touchedFiles = new Set();
+
+  sessionHistory.forEach((message) => {
+    if (message?.kind !== 'tool_use') {
+      return;
+    }
+
+    const toolName = readString(message.toolName);
+    if (!toolName || !FILE_EDIT_TOOL_NAMES.has(toolName)) {
+      return;
+    }
+
+    collectPathCandidates(message.toolInput).forEach((candidate) => {
+      const normalized = normalizeProjectRelativePath(projectPath, candidate);
+      if (normalized) {
+        touchedFiles.add(normalized);
+      }
+    });
+  });
+
+  return [...touchedFiles];
+};
+
+const buildTouchedFileSnapshots = async (projectPath, touchedFiles, maxTotalChars = 5000) => {
+  const snapshots = [];
+  let remaining = maxTotalChars;
+
+  for (const relativePath of touchedFiles.slice(0, 8)) {
+    if (remaining <= 0) {
+      break;
+    }
+
+    try {
+      const absolutePath = path.join(projectPath, relativePath);
+      const raw = await fs.readFile(absolutePath, 'utf8');
+      const excerpt = truncateOutput(raw, Math.min(remaining, 1400));
+      snapshots.push({
+        path: relativePath,
+        excerpt,
+      });
+      remaining -= excerpt.length;
+    } catch {
+      snapshots.push({
+        path: relativePath,
+        excerpt: '[file could not be read after the pass]',
+      });
+      remaining -= 80;
+    }
+  }
+
+  return snapshots;
+};
+
+const persistSlicePassArtifact = async ({
+  projectPath,
+  builderSessionId,
+  task,
+  passNumber,
+  actorType,
+  actorLabel,
+  childSessionId,
+  provider,
+  model,
+  summary,
+  errors,
+  sessionHistory,
+}) => {
+  const touchedFiles = extractTouchedFilesFromHistory(sessionHistory, projectPath);
+  const fileSnapshots = await buildTouchedFileSnapshots(projectPath, touchedFiles);
+  const artifactDir = path.join(
+    projectPath,
+    BUILDER_ARTIFACT_DIR,
+    'passes',
+    sanitizeFileName(builderSessionId),
+  );
+  const artifactPath = path.join(
+    artifactDir,
+    `task-${task.id}-pass-${passNumber}-${sanitizeFileName(actorType)}.json`,
+  );
+
+  await fs.mkdir(artifactDir, { recursive: true });
+
+  const artifact = {
+    builderSessionId,
+    childSessionId,
+    task,
+    passNumber,
+    actorType,
+    actorLabel,
+    provider,
+    model,
+    touchedFiles,
+    fileSnapshots,
+    summary,
+    errors,
+  };
+
+  await fs.writeFile(artifactPath, `${JSON.stringify(artifact, null, 2)}\n`, 'utf8');
+
+  const contextForNextPass = [
+    `Previous pass artifact: ${artifactPath}`,
+    touchedFiles.length > 0 ? `Touched files from previous pass: ${touchedFiles.join(', ')}` : 'Touched files from previous pass: not detected from tool history.',
+    fileSnapshots.length > 0
+      ? [
+        'Current code excerpts from the previous pass:',
+        ...fileSnapshots.map((entry) => [
+          `File: ${entry.path}`,
+          '```',
+          entry.excerpt,
+          '```',
+        ].join('\n')),
+      ].join('\n')
+      : '',
+  ].filter(Boolean).join('\n\n');
+
+  return {
+    artifactPath,
+    touchedFiles,
+    fileSnapshots,
+    contextForNextPass,
+  };
+};
