+const runTaskGraphWithConcurrency = async ({
+  tasks,
+  limit,
+  worker,
+  createBlockedResult,
+  onForcedScheduling,
+}) => {
+  const pending = tasks.map((task, index) => ({ task, index }));
+  const inFlight = new Map();
+  const results = new Map();
+
+  const dependencyStatesFor = (task) => (task.dependsOn || []).map((dependencyId) => results.get(dependencyId));
+  const isTaskReady = (task) => (task.dependsOn || []).every((dependencyId) => {
+    const dependencyResult = results.get(dependencyId);
+    return dependencyResult?.ok;
+  });
+
+  while (pending.length > 0 || inFlight.size > 0) {
+    while (inFlight.size < limit && pending.length > 0) {
+      let readyIndex = pending.findIndex(({ task }) => isTaskReady(task));
+      if (readyIndex === -1) {
+        const hasOnlyPendingDependencies = pending.findIndex(({ task }) => {
+          const dependencyStates = dependencyStatesFor(task);
+          return dependencyStates.length === 0 || dependencyStates.every((dependencyState) => !dependencyState);
+        });
+        if (hasOnlyPendingDependencies !== -1 && inFlight.size === 0) {
+          readyIndex = hasOnlyPendingDependencies;
+          await onForcedScheduling?.(pending[readyIndex].task);
+        }
+      }
+
+      if (readyIndex === -1) {
+        break;
+      }
+
+      const [{ task, index }] = pending.splice(readyIndex, 1);
+      const scheduled = Promise.resolve(worker(task, index)).then((result) => ({ id: task.id, result }));
+      inFlight.set(task.id, scheduled);
+    }
+
+    if (inFlight.size === 0) {
+      break;
+    }
+
+    const { id, result } = await Promise.race([...inFlight.values()]);
+    inFlight.delete(id);
+    results.set(id, result);
+  }
+
+  for (const { task, index } of pending) {
+    const blockedDependencies = (task.dependsOn || []).filter((dependencyId) => {
+      const dependencyResult = results.get(dependencyId);
+      return dependencyResult && !dependencyResult.ok;
+    });
+    results.set(task.id, await createBlockedResult(task, index, blockedDependencies));
+  }
+
+  return tasks.map((task) => results.get(task.id));
+};
