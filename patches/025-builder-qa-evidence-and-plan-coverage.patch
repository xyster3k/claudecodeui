+      ambiguousPoints: readStringArray(parsed?.ambiguous_points || parsed?.ambiguousPoints),
+      outOfScopeRisks: readStringArray(parsed?.out_of_scope_risks || parsed?.outOfScopeRisks),
+    };
+  } catch {
+    return {
+      approved: false,
+      coverageSummary: 'Plan coverage review returned invalid JSON.',
+      missingRequirements: ['The system could not confirm that the plan covers the full user request.'],
+      ambiguousPoints: [],
+      outOfScopeRisks: [],
+    };
   }
 };
 
