+const parsePlanCoverageReview = (text) => {
+  const jsonBlock = extractJsonBlock(text);
+  if (!jsonBlock) {
+    return {
+      approved: false,
+      coverageSummary: 'Plan coverage review did not return structured output.',
+      missingRequirements: ['The system could not confirm that the plan covers the full user request.'],
+      ambiguousPoints: [],
+      outOfScopeRisks: [],
+    };
+  }
+
+  try {
+    const parsed = JSON.parse(stripCodeFences(jsonBlock));
+    return {
+      approved: Boolean(parsed?.approved),
+      coverageSummary: readString(parsed?.coverage_summary) || readString(parsed?.coverageSummary) || 'No coverage summary provided.',
