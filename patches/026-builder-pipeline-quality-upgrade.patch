+const runProviderTaskWithTimeout = async ({ provider, prompt, options, writer, timeoutMs }) => {
+  if (!timeoutMs || !Number.isFinite(timeoutMs) || timeoutMs <= 0) {
+    return runProviderTask({ provider, prompt, options, writer });
+  }
+
+  const timeoutPromise = new Promise((_, reject) => {
+    const timer = setTimeout(() => {
+      reject(new Error(`Provider task timed out after ${Math.round(timeoutMs / 1000)}s`));
+    }, timeoutMs);
+    timer.unref?.();
+  });
+
+  return Promise.race([
+    runProviderTask({ provider, prompt, options, writer }),
+    timeoutPromise,
+  ]);
+};
