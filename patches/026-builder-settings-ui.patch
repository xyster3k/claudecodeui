diff --git a/src/components/settings/view/tabs/builder-settings/BuilderSettingsTab.tsx b/src/components/settings/view/tabs/builder-settings/BuilderSettingsTab.tsx
new file mode 100644
index 0000000..034e211
--- /dev/null
+++ b/src/components/settings/view/tabs/builder-settings/BuilderSettingsTab.tsx
@@ -0,0 +1,288 @@
+import { useTranslation } from 'react-i18next';
+import SettingsCard from '../../SettingsCard';
+import SettingsRow from '../../SettingsRow';
+import SettingsSection from '../../SettingsSection';
+import SettingsToggle from '../../SettingsToggle';
+import type { BuilderSettingsState } from '../../../types/types';
+import {
+  CLAUDE_MODELS,
+  CURSOR_MODELS,
+  CODEX_MODELS,
+  GEMINI_MODELS,
+} from '../../../../../../shared/modelConstants';
+
+type ModelOption = { value: string; label: string };
+
+const ALL_MODELS: { provider: string; options: ModelOption[] }[] = [
+  { provider: 'Claude', options: CLAUDE_MODELS.OPTIONS },
+  { provider: 'Codex (OpenAI)', options: CODEX_MODELS.OPTIONS },
+  { provider: 'Cursor', options: CURSOR_MODELS.OPTIONS },
+  { provider: 'Gemini', options: GEMINI_MODELS.OPTIONS },
+];
+
+const REASONING_LEVELS = [
+  { value: 'low', label: 'Low' },
+  { value: 'medium', label: 'Medium' },
+  { value: 'high', label: 'High' },
+  { value: 'max', label: 'Max' },
+];
+
+const QA_PROVIDERS = [
+  { value: '', label: 'Auto (different from primary)' },
+  { value: 'claude', label: 'Claude' },
+  { value: 'codex', label: 'Codex (OpenAI)' },
+  { value: 'cursor', label: 'Cursor' },
+  { value: 'gemini', label: 'Gemini' },
+];
+
+const selectClass =
+  'w-full rounded-lg border border-input bg-card p-2.5 text-sm text-foreground touch-manipulation focus:border-primary focus:ring-1 focus:ring-primary sm:w-52';
+
+type ModelSelectProps = {
+  value: string;
+  onChange: (value: string) => void;
+};
+
+function ModelSelect({ value, onChange }: ModelSelectProps) {
+  return (
+    <select
+      value={value}
+      onChange={(e) => onChange(e.target.value)}
+      className={selectClass}
+    >
+      <option value="">Default (auto)</option>
+      {ALL_MODELS.map((group) => (
+        <optgroup key={group.provider} label={group.provider}>
+          {group.options.map((opt) => (
+            <option key={opt.value} value={opt.value}>
+              {opt.label}
+            </option>
+          ))}
+        </optgroup>
+      ))}
+    </select>
+  );
+}
+
+type BuilderSettingsTabProps = {
+  builderSettings: BuilderSettingsState;
+  onBuilderSettingsChange: (settings: BuilderSettingsState) => void;
+};
+
+export default function BuilderSettingsTab({
+  builderSettings,
+  onBuilderSettingsChange,
+}: BuilderSettingsTabProps) {
+  const { t } = useTranslation('settings');
+
+  const update = <K extends keyof BuilderSettingsState>(
+    section: K,
+    field: string,
+    value: unknown,
+  ) => {
+    onBuilderSettingsChange({
+      ...builderSettings,
+      [section]: {
+        ...builderSettings[section],
+        [field]: value,
+      },
+    });
+  };
+
+  return (
+    <div className="space-y-8">
+      {/* Pipeline Models */}
+      <SettingsSection
+        title={t('builderSettings.models.title', 'Pipeline Models')}
+        description={t(
+          'builderSettings.models.description',
+          'Choose which AI model to use at each stage of the builder pipeline.',
+        )}
+      >
+        <SettingsCard divided>
+          <SettingsRow
+            label={t('builderSettings.models.planner', 'Planner Model')}
+            description="Senior architect that analyzes the request and creates the execution plan."
+          >
+            <ModelSelect
+              value={builderSettings.orchestration.plannerModel}
+              onChange={(v) => update('orchestration', 'plannerModel', v)}
+            />
+          </SettingsRow>
+
+          <SettingsRow
+            label={t('builderSettings.models.worker', 'Worker Model')}
+            description="Implements individual slices of the plan in parallel."
+          >
+            <ModelSelect
+              value={builderSettings.orchestration.workerModel}
+              onChange={(v) => update('orchestration', 'workerModel', v)}
+            />
+          </SettingsRow>
+
+          <SettingsRow
+            label={t('builderSettings.models.integrator', 'Integrator Model')}
+            description="Merges worker outputs, resolves conflicts, and normalizes code."
+          >
+            <ModelSelect
+              value={builderSettings.orchestration.integratorModel}
+              onChange={(v) => update('orchestration', 'integratorModel', v)}
+            />
+          </SettingsRow>
+        </SettingsCard>
+      </SettingsSection>
+
+      {/* QA Configuration */}
+      <SettingsSection
+        title={t('builderSettings.qa.title', 'Quality Assurance')}
+        description={t(
+          'builderSettings.qa.description',
+          'QA evaluates the final result against your original request. Uses a different provider for independent review.',
+        )}
+      >
+        <SettingsCard divided>
+          <SettingsRow
+            label={t('builderSettings.qa.enabled', 'Enable QA Stage')}
+            description="Run a final quality check comparing output to the original request and plan."
+          >
+            <SettingsToggle
+              checked={builderSettings.qa.enabled}
+              onChange={(v) => update('qa', 'enabled', v)}
+              ariaLabel="Enable QA stage"
+            />
+          </SettingsRow>
+
+          <SettingsRow
+            label={t('builderSettings.qa.provider', 'QA Provider')}
+            description="Which provider runs QA. 'Auto' picks a different one from the primary."
+          >
+            <select
+              value={builderSettings.qa.provider}
+              onChange={(e) => update('qa', 'provider', e.target.value)}
+              className={selectClass}
+              disabled={!builderSettings.qa.enabled}
+            >
+              {QA_PROVIDERS.map((opt) => (
+                <option key={opt.value} value={opt.value}>
+                  {opt.label}
+                </option>
+              ))}
+            </select>
+          </SettingsRow>
+
+          <SettingsRow
+            label={t('builderSettings.qa.model', 'QA Model')}
+            description="Specific model for QA. Leave as default to auto-select."
+          >
+            <ModelSelect
+              value={builderSettings.qa.model}
+              onChange={(v) => update('qa', 'model', v)}
+            />
+          </SettingsRow>
+        </SettingsCard>
+      </SettingsSection>
+
+      {/* Reasoning Levels */}
+      <SettingsSection
+        title={t('builderSettings.reasoning.title', 'Reasoning Effort')}
+        description={t(
+          'builderSettings.reasoning.description',
+          'Control how much reasoning budget each stage gets. Higher = better results but slower and more expensive.',
+        )}
+      >
+        <SettingsCard divided>
+          {(['planner', 'worker', 'integrator', 'qa'] as const).map((stage) => (
+            <SettingsRow
+              key={stage}
+              label={t(
+                `builderSettings.reasoning.${stage}`,
+                `${stage.charAt(0).toUpperCase() + stage.slice(1)}`,
+              )}
+              description={
+                stage === 'planner'
+                  ? 'Architectural analysis and plan creation'
+                  : stage === 'worker'
+                    ? 'Code implementation per slice'
+                    : stage === 'integrator'
+                      ? 'Merging and conflict resolution'
+                      : 'Final quality evaluation'
+              }
+            >
+              <select
+                value={builderSettings.reasoning[stage]}
+                onChange={(e) => update('reasoning', stage, e.target.value)}
+                className={selectClass}
+              >
+                {REASONING_LEVELS.map((opt) => (
+                  <option key={opt.value} value={opt.value}>
+                    {opt.label}
+                  </option>
+                ))}
+              </select>
+            </SettingsRow>
+          ))}
+        </SettingsCard>
+      </SettingsSection>
+
+      {/* Orchestration */}
+      <SettingsSection
+        title={t('builderSettings.orchestration.title', 'Orchestration')}
+        description={t(
+          'builderSettings.orchestration.description',
+          'Control parallelism, timeouts, and re-planning behavior.',
+        )}
+      >
+        <SettingsCard divided>
+          <SettingsRow
+            label={t('builderSettings.orchestration.parallelWorkers', 'Parallel Workers')}
+            description="Number of workers that execute simultaneously (1-4)."
+          >
+            <select
+              value={String(builderSettings.orchestration.maxParallelWorkers)}
+              onChange={(e) =>
+                update('orchestration', 'maxParallelWorkers', Number(e.target.value))
+              }
+              className={selectClass}
+            >
+              {[1, 2, 3, 4].map((n) => (
+                <option key={n} value={String(n)}>
+                  {n}
+                </option>
+              ))}
+            </select>
+          </SettingsRow>
+
+          <SettingsRow
+            label={t('builderSettings.orchestration.maxReplanAttempts', 'Max Re-plan Attempts')}
+            description="How many times the planner can retry if the coverage review rejects the plan."
+          >
+            <select
+              value={String(builderSettings.orchestration.maxReplanAttempts)}
+              onChange={(e) =>
+                update('orchestration', 'maxReplanAttempts', Number(e.target.value))
+              }
+              className={selectClass}
+            >
+              {[0, 1, 2, 3, 4, 5].map((n) => (
+                <option key={n} value={String(n)}>
+                  {n}
+                </option>
+              ))}
+            </select>
+          </SettingsRow>
+
+          <SettingsRow
+            label={t('builderSettings.orchestration.plannerCheckpoint', 'Planner Checkpoint Review')}
+            description="Review and approve the plan before workers start."
+          >
+            <SettingsToggle
+              checked={builderSettings.supervision.plannerCheckpointReview}
+              onChange={(v) => update('supervision', 'plannerCheckpointReview', v)}
+              ariaLabel="Planner checkpoint review"
+            />
+          </SettingsRow>
+        </SettingsCard>
+      </SettingsSection>
+    </div>
+  );
+}
