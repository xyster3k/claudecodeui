+/**
+ * Strips common thinking-mode prefixes from user messages.
+ */
+function stripThinkingPrefix(text: string): string {
+  return text.replace(/^(ultrathink|think\s*hard(?:er)?|think)\s*:\s*/i, '').trim();
+}
+
+/**
+ * Extracts a human-readable session name from a Claude JSONL transcript file.
+ */
+export async function extractSessionNameFromJsonl(
+  filePath: string,
+  fallback: string
+): Promise<string> {
+  try {
+    const fileStream = fs.createReadStream(filePath);
+    const lineReader = readline.createInterface({ input: fileStream, crlfDelay: Infinity });
+    let linesRead = 0;
+
+    for await (const line of lineReader) {
+      if (++linesRead > 30) break;
+      const trimmed = line.trim();
+      if (!trimmed) continue;
+      const parsed = JSON.parse(trimmed);
+      if (parsed?.type !== 'user') continue;
+
+      const content = parsed?.message?.content;
+      let text = '';
+      if (Array.isArray(content) && content.length > 0 && typeof content[0]?.text === 'string') {
+        text = content[0].text;
+      } else if (typeof content === 'string') {
+        text = content;
+      }
+      text = stripThinkingPrefix(text).replace(/\s+/g, ' ').trim();
+      if (text) {
+        lineReader.close();
+        fileStream.close();
+        return text.slice(0, 100);
+      }
+    }
+  } catch {
+    // fall through
+  }
+  return fallback;
+}
+
+/**
+ * Extracts a session name from a Codex JSONL transcript file.
+ */
+export async function extractCodexSessionNameFromJsonl(
+  filePath: string,
+  fallback: string
+): Promise<string> {
+  try {
+    const fileStream = fs.createReadStream(filePath);
+    const lineReader = readline.createInterface({ input: fileStream, crlfDelay: Infinity });
+    let linesRead = 0;
+    let userMessageCount = 0;
+
+    for await (const line of lineReader) {
+      if (++linesRead > 50) break;
+      const trimmed = line.trim();
+      if (!trimmed) continue;
+      const parsed = JSON.parse(trimmed);
+      const payload = parsed?.payload;
+      if (payload?.type !== 'message' || payload?.role !== 'user') continue;
+      userMessageCount++;
+      if (userMessageCount < 2) continue;
+
+      const content = payload?.content;
+      let text = '';
+      if (Array.isArray(content)) {
+        const textItem = content.find((c: Record<string, unknown>) => typeof c?.text === 'string');
+        text = textItem?.text ?? '';
+      } else if (typeof content === 'string') {
+        text = content;
+      }
+      text = stripThinkingPrefix(text).replace(/\s+/g, ' ').trim();
+      if (text) {
+        lineReader.close();
+        fileStream.close();
+        return text.slice(0, 100);
+      }
+    }
+  } catch {
+    // fall through
+  }
+  return fallback;
+}
