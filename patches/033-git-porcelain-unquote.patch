+/**
+ * Git's --porcelain output wraps filenames containing spaces or special chars
+ * in double-quotes and may use C-style escapes (e.g. \\ for backslash,
+ * \" for double-quote, \nnn for octal bytes).  Strip the surrounding quotes
+ * and unescape sequences so the rest of the code sees the real path.
+ * Octal sequences are collected into a byte buffer and decoded as UTF-8
+ * so that multi-byte characters (e.g. Cyrillic, CJK) come through correctly.
+ */
+function unquoteGitPath(p) {
+  if (!(p.length >= 2 && p.startsWith('"') && p.endsWith('"'))) return p;
+  const inner = p.slice(1, -1);
+  const bytes = [];
+  for (let i = 0; i < inner.length; i++) {
+    if (inner[i] === '\\' && i + 1 < inner.length) {
+      const next = inner[i + 1];
+      if (next === '"')  { bytes.push(0x22); i++; }
+      else if (next === '\\') { bytes.push(0x5C); i++; }
+      else if (next === 'n')  { bytes.push(0x0A); i++; }
+      else if (next === 't')  { bytes.push(0x09); i++; }
+      else if (next >= '0' && next <= '7' && i + 3 < inner.length) {
+        bytes.push(parseInt(inner.slice(i + 1, i + 4), 8));
+        i += 3;
+      } else { bytes.push(inner.charCodeAt(i)); }
+    } else {
+      bytes.push(inner.charCodeAt(i));
+    }
+  }
+  return Buffer.from(bytes).toString('utf8');
+}
