+/**
+ * Auto-detect the provider that owns a given model name.
+ * Returns 'claude', 'codex', 'gemini', or null if unknown.
+ */
+const providerForModel = (model) => {
+  if (!model) return null;
+  const m = model.toLowerCase();
+  if (/^(gpt-|o[1-4](-|$)|codex|davinci|text-)/.test(m)) return 'codex';
+  if (/^(claude-|opus|sonnet|haiku)/.test(m)) return 'claude';
+  if (/^(gemini|models\/)/.test(m)) return 'gemini';
+  return null;
+};
