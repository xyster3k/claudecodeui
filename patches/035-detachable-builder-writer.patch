@@ -0,0 +1,193 @@
+/**
+ * DetachableWriter — a proxy between the builder pipeline and the WebSocket.
+ *
+ * Purpose: lets builder runs survive browser disconnects. Messages are always
+ * logged to an in-memory ring buffer; when a WebSocket writer is attached,
+ * messages are also forwarded in real time. When the browser disconnects the
+ * writer is set to null — the pipeline keeps running, and the buffer keeps
+ * accumulating. On reconnect, attach() replays missed messages and re-sends
+ * pending approval requests.
+ */
+
+const MESSAGE_LOG_CAP = 2000;
+
+export class DetachableWriter {
+  constructor(sessionId, provider) {
+    this.sessionId = sessionId;
+    this.provider = provider;
+    /** Duck-type compat — code checks `writer.isWebSocketWriter` */
+    this.isWebSocketWriter = true;
+    /** Ring buffer of all messages sent by the pipeline */
+    this.messageLog = [];
+    /** The live WebSocket writer — null when browser is disconnected */
+    this.wsWriter = null;
+    /** requestId → { resolve, message } for approvals awaiting user response */
+    this.pendingApprovals = new Map();
+    /** Track the current run phase for status queries */
+    this.currentPhase = 'initializing';
+    /** The original command */
+    this.command = '';
+  }
+
+  /**
+   * Attach a new WebSocket writer and replay missed messages.
+   * @param {object} wsWriter - WebSocketWriter instance
+   * @param {number} fromIndex - replay messages starting from this index
+   */
+  attach(wsWriter, fromIndex = 0) {
+    this.wsWriter = wsWriter;
+    const startIndex = Math.max(0, Math.min(fromIndex, this.messageLog.length));
+    for (let i = startIndex; i < this.messageLog.length; i++) {
+      try {
+        this.wsWriter.send(this.messageLog[i]);
+      } catch {
+        // If send fails during replay, detach
+        this.wsWriter = null;
+        return;
+      }
+    }
+    // Re-send pending approval requests so the reconnected user sees them
+    for (const [, entry] of this.pendingApprovals) {
+      try {
+        this.wsWriter.send(entry.message);
+      } catch {
+        this.wsWriter = null;
+        return;
+      }
+    }
+  }
+
+  /**
+   * Detach the WebSocket writer (browser disconnected).
+   */
+  detach() {
+    this.wsWriter = null;
+  }
+
+  /**
+   * Send a message. Always logs; forwards to WS only if attached.
+   */
+  send(message) {
+    this.messageLog.push(message);
+    if (this.messageLog.length > MESSAGE_LOG_CAP) {
+      this.messageLog.shift();
+    }
+    if (this.wsWriter) {
+      try {
+        this.wsWriter.send(message);
+      } catch {
+        // Send failed — detach silently, pipeline continues
+        this.wsWriter = null;
+      }
+    }
+  }
+
+  /**
+   * Register a pending approval (called from waitForBuilderApproval).
+   * @param {string} requestId
+   * @param {Function} resolve - Promise resolve callback
+   * @param {object} message - the permission_request message to replay on reconnect
+   */
+  registerApproval(requestId, resolve, message) {
+    this.pendingApprovals.set(requestId, { resolve, message });
+  }
+
+  /**
+   * Resolve a pending approval (user responded).
+   * @param {string} requestId
+   * @param {object} decision - { allow: boolean, message?: string }
+   * @returns {boolean} true if the approval was found and resolved
+   */
+  resolveApproval(requestId, decision) {
+    const pending = this.pendingApprovals.get(requestId);
+    if (!pending) {
+      return false;
+    }
+    this.pendingApprovals.delete(requestId);
+    pending.resolve(decision);
+    return true;
+  }
+
+  /**
+   * Check if this writer has pending approvals.
+   */
+  hasPendingApprovals() {
+    return this.pendingApprovals.size > 0;
+  }
+
+  /**
+   * Get the number of logged messages (for replay index).
+   */
+  getMessageCount() {
+    return this.messageLog.length;
+  }
+
+  /**
+   * Check if a WebSocket writer is currently attached.
+   */
+  isAttached() {
+    return this.wsWriter !== null;
+  }
+}
+
+/**
+ * Registry of active DetachableWriters, keyed by builder sessionId.
+ * Used by the WS close handler and reattach handler.
+ */
+const activeDetachableWriters = new Map();
+
+/**
+ * Create and register a DetachableWriter for a builder run.
+ */
+export function createDetachableWriter(sessionId, provider, wsWriter) {
+  const dw = new DetachableWriter(sessionId, provider);
+  dw.attach(wsWriter);
+  activeDetachableWriters.set(sessionId, dw);
+  return dw;
+}
+
+/**
+ * Remove a DetachableWriter from the registry (run finished).
+ */
+export function removeDetachableWriter(sessionId) {
+  activeDetachableWriters.delete(sessionId);
+}
+
+/**
+ * Get a DetachableWriter by session ID.
+ */
+export function getDetachableWriter(sessionId) {
+  return activeDetachableWriters.get(sessionId) || null;
+}
+
+/**
+ * Detach all DetachableWriters that reference the given wsWriter.
+ * Called when a WebSocket connection closes.
+ */
+export function detachWritersByWs(wsWriter) {
+  for (const [, dw] of activeDetachableWriters) {
+    if (dw.wsWriter === wsWriter) {
+      dw.detach();
+    }
+  }
+}
+
+/**
+ * Attempt to resolve a builder approval across all active DetachableWriters.
+ * Returns true if the approval was found and resolved.
+ */
+export function resolveBuilderApprovalFromWriters(requestId, decision) {
+  for (const [, dw] of activeDetachableWriters) {
+    if (dw.resolveApproval(requestId, decision)) {
+      return true;
+    }
+  }
+  return false;
+}
+
+/**
+ * List all active DetachableWriters (for REST API).
+ */
+export function getActiveDetachableWriters() {
+  return activeDetachableWriters;
+}
