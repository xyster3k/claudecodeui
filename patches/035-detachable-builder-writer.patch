diff --git a/server/routes/builder.js b/server/routes/builder.js
new file mode 100644
index 0000000..5a1c6c9
--- /dev/null
+++ b/server/routes/builder.js
@@ -0,0 +1,88 @@
+import { Router } from 'express';
+import { getActiveBuilderRuns, abortBuilderWorkflow } from '../builder-mode.js';
+import { getActiveDetachableWriters } from '../builder-detachable-writer.js';
+
+const router = Router();
+
+/**
+ * GET /api/builder/runs
+ * List active builder runs (in-memory only — these are live, running builds).
+ */
+router.get('/runs', (_req, res) => {
+  const activeRuns = getActiveBuilderRuns();
+  const detachableWriters = getActiveDetachableWriters();
+  const runs = [];
+
+  for (const [sessionId, runState] of activeRuns) {
+    const dw = detachableWriters.get(sessionId);
+    runs.push({
+      sessionId,
+      provider: runState.provider,
+      command: dw?.command || runState.record?.command || '',
+      phase: runState.record?.phase || 'initializing',
+      status: runState.record?.status || 'running',
+      aborted: runState.aborted,
+      attached: dw ? dw.isAttached() : false,
+      hasPendingApprovals: dw ? dw.hasPendingApprovals() : false,
+      messageCount: dw ? dw.getMessageCount() : 0,
+      createdAt: runState.record?.createdAt || null,
+      updatedAt: runState.record?.updatedAt || null,
+      projectPath: runState.record?.projectPath || '',
+      metrics: runState.record?.metrics || null,
+    });
+  }
+
+  res.json({ runs });
+});
+
+/**
+ * GET /api/builder/runs/:sessionId
+ * Get single run status.
+ */
+router.get('/runs/:sessionId', (req, res) => {
+  const { sessionId } = req.params;
+  const activeRuns = getActiveBuilderRuns();
+  const runState = activeRuns.get(sessionId);
+
+  if (!runState) {
+    res.status(404).json({ error: 'Run not found or not active' });
+    return;
+  }
+
+  const detachableWriters = getActiveDetachableWriters();
+  const dw = detachableWriters.get(sessionId);
+
+  res.json({
+    sessionId,
+    provider: runState.provider,
+    command: dw?.command || runState.record?.command || '',
+    phase: runState.record?.phase || 'initializing',
+    status: runState.record?.status || 'running',
+    aborted: runState.aborted,
+    attached: dw ? dw.isAttached() : false,
+    hasPendingApprovals: dw ? dw.hasPendingApprovals() : false,
+    messageCount: dw ? dw.getMessageCount() : 0,
+    createdAt: runState.record?.createdAt || null,
+    updatedAt: runState.record?.updatedAt || null,
+    projectPath: runState.record?.projectPath || '',
+    metrics: runState.record?.metrics || null,
+    tasks: runState.record?.tasks || [],
+  });
+});
+
+/**
+ * POST /api/builder/runs/:sessionId/abort
+ * Abort a builder run via REST (doesn't require active WebSocket).
+ */
+router.post('/runs/:sessionId/abort', async (req, res) => {
+  const { sessionId } = req.params;
+  try {
+    const success = await abortBuilderWorkflow(sessionId);
+    res.json({ success });
+  } catch (error) {
+    const message = error instanceof Error ? error.message : String(error);
+    res.status(500).json({ error: message });
+  }
+});
+
+export default router;
